{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "【取得】昇順 (1 →)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/mega_scraper.py",
            "console": "integratedTerminal",
            "args": [
                "--headless",
                "--year", "${input:academicYear}",
                "--direction", "up",
                "--batch", "${input:batchAmount}",
                "--start", "${input:startIdUp}"
            ],
            "justMyCode": true
        },
        {
            "name": "【取得】降順 (99999 →)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/mega_scraper.py",
            "console": "integratedTerminal",
            "args": [
                "--headless",
                "--year", "${input:academicYear}",
                "--direction", "down",
                "--batch", "${input:batchAmount}",
                "--start", "${input:startIdDown}"
            ],
            "justMyCode": true
        },
        {
            "name": "【統合】昇順・降順データをマージ",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/merge_results.py",
            "console": "integratedTerminal",
            "args": [
                "--year", "${input:academicYear}"
            ],
            "justMyCode": true
        },
        {
            "name": "【出力】CSV/JSON 生成",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/jsonl_to_csv.py",
            "console": "integratedTerminal",
            "args": [
                "--input", "syllabus_${input:academicYear}.jsonl",
                "--output", "syllabus_${input:academicYear}.csv"
            ],
            "justMyCode": true
        },
        {
            "name": "[1] ブラウザ起動 (Chrome Debug mode)",
            "type": "node-terminal",
            "request": "launch",
            "command": "./start_chrome_debug.sh",
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "[2] 認証情報を保存 (save_auth.py)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/save_auth.py",
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ],
    "inputs": [
        {
            "id": "academicYear",
            "type": "promptString",
            "description": "対象の年度を入力してください (例: 2026)",
            "default": "2026"
        },
        {
            "id": "batchAmount",
            "type": "promptString",
            "description": "取得する件数を入力してください (例: 1000)",
            "default": "1000"
        },
        {
            "id": "startIdUp",
            "type": "promptString",
            "description": "【昇順】開始ID (空欄なら進捗ファイルから再開)",
            "default": ""
        },
        {
            "id": "startIdDown",
            "type": "promptString",
            "description": "【降順】開始ID (空欄なら進捗ファイルから再開)",
            "default": ""
        }
    ]
}
